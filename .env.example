# ─── RF SCYTHE / NerfEngine — Environment Configuration ─────────────────────
# Copy to .env and adjust for your deployment.
#
#   cp .env.example .env

# ── Orchestrator ──────────────────────────────────────────────────────────────
ORCHESTRATOR_PORT=5001
STREAM_RELAY_PORT=8765
MCP_WS_PORT=8766

# Stream relay URL seen by the browser UI and Android client.
# Must be reachable from the device running the browser (not internal Docker IP).
# Example for a local LAN server at 192.168.1.185:
STREAM_RELAY_URL=ws://192.168.1.185:8765/ws
MCP_WS_URL=ws://192.168.1.185:8766/ws

# TAK-ML integration (optional)
TAKML_URL=http://localhost:8234

# External live-data feeds (optional)
AISSTREAM_API_KEY=
N2YO_API_KEY=
CESIUM_ION_TOKEN=
STADIA_API_KEY=

# ── Ollama ────────────────────────────────────────────────────────────────────
OLLAMA_PORT=11434

# Linux + host networking: localhost works because containers share network stack.
# macOS / Windows + bridge: use http://ollama:11434 (service name on scythe-net).
OLLAMA_URL=http://localhost:11434
